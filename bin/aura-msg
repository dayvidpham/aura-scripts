#!/usr/bin/env python3
"""aura-msg — Aura Protocol model harness CLI.

Subcommand groups:
    query    — Read workflow state (query-state)
    signal   — Send signals (signal-vote, signal-complete)
    phase    — Phase transitions (advance-phase)
    epoch    — Epoch lifecycle (start-epoch)
    session  — Session registration (session-register)

Usage:
    aura-msg --help
    aura-msg <group> --help
    aura-msg <group> <subcommand> --help
"""

import argparse
import asyncio
import sys

from aura_protocol.config import default_config_path, load_yaml_section, resolve_connection
from aura_protocol.formatters import format_epoch_state


def _add_connection_args(parser: argparse.ArgumentParser) -> None:
    """Add shared Temporal connection arguments to a subcommand parser."""
    parser.add_argument("--epoch-id", required=True, help="Epoch workflow ID")
    parser.add_argument(
        "--namespace",
        default=None,
        help="Temporal namespace (overrides config/env)",
    )
    parser.add_argument(
        "--task-queue",
        default=None,
        help="Temporal task queue (overrides config/env)",
    )
    parser.add_argument(
        "--server-address",
        default=None,
        help="Temporal server address (overrides config/env)",
    )
    parser.add_argument(
        "--config",
        default=None,
        metavar="PATH",
        help="Path to YAML config file (default: ~/.config/aura/plugins/aurad.config.yaml)",
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="aura-msg",
        description="Aura Protocol model harness CLI.",
    )
    subparsers = parser.add_subparsers(dest="group", metavar="<group>")

    # ── query group ───────────────────────────────────────────────────────────
    query_p = subparsers.add_parser("query", help="Read workflow state")
    query_sub = query_p.add_subparsers(dest="subcommand", metavar="<subcommand>")

    qs = query_sub.add_parser("state", help="Query current epoch state")
    _add_connection_args(qs)
    qs.add_argument(
        "--format",
        choices=["json", "text"],
        default="json",
        help="Output format (default: json)",
    )

    # ── signal group ──────────────────────────────────────────────────────────
    signal_p = subparsers.add_parser("signal", help="Send signals to a workflow")
    signal_sub = signal_p.add_subparsers(dest="subcommand", metavar="<subcommand>")

    sv = signal_sub.add_parser("vote", help="Submit a reviewer vote")
    _add_connection_args(sv)
    sv.add_argument(
        "--axis",
        required=True,
        choices=["correctness", "test_quality", "elegance"],
        help="Review axis",
    )
    sv.add_argument(
        "--vote",
        required=True,
        choices=["accept", "revise"],
        help="Vote value",
    )
    sv.add_argument("--reviewer-id", required=True, help="Unique reviewer identifier")

    sc = signal_sub.add_parser("complete", help="Signal slice completion")
    _add_connection_args(sc)
    sc.add_argument("--slice-id", required=True, help="Slice identifier")
    sc_output = sc.add_mutually_exclusive_group()
    sc_output.add_argument("--output", metavar="TEXT", help="Completion output (sets success=True)")
    sc_output.add_argument("--error", metavar="TEXT", help="Error message (sets success=False)")

    # ── phase group ───────────────────────────────────────────────────────────
    phase_p = subparsers.add_parser("phase", help="Phase transition commands")
    phase_sub = phase_p.add_subparsers(dest="subcommand", metavar="<subcommand>")

    pa = phase_sub.add_parser("advance", help="Request a phase transition")
    _add_connection_args(pa)
    pa.add_argument("--to-phase", required=True, help="Target phase (e.g. p10)")
    pa.add_argument("--triggered-by", required=True, help="Who triggered this")
    pa.add_argument("--condition", required=True, help="Condition string from transition table")

    # ── epoch group ───────────────────────────────────────────────────────────
    epoch_p = subparsers.add_parser("epoch", help="Epoch lifecycle commands")
    epoch_sub = epoch_p.add_subparsers(dest="subcommand", metavar="<subcommand>")

    es = epoch_sub.add_parser("start", help="Start a new epoch workflow")
    es.add_argument("--epoch-id", required=True, help="Unique epoch identifier")
    es.add_argument("--description", required=True, help="Human-readable epoch description")
    es.add_argument("--namespace", default=None, help="Temporal namespace")
    es.add_argument("--task-queue", default=None, help="Temporal task queue")
    es.add_argument("--server-address", default=None, help="Temporal server address")
    es.add_argument("--config", default=None, metavar="PATH", help="Config file path")

    # ── session group ─────────────────────────────────────────────────────────
    session_p = subparsers.add_parser("session", help="Session registration commands")
    session_sub = session_p.add_subparsers(dest="subcommand", metavar="<subcommand>")

    sr = session_sub.add_parser("register", help="Register a Claude Code session")
    _add_connection_args(sr)
    sr.add_argument("--role", required=True, help="Agent role (e.g. worker, reviewer)")
    sr.add_argument("--session-id", required=True, help="Unique session identifier")

    return parser


def _resolve_conn(args: argparse.Namespace) -> object:
    """Resolve Temporal connection config from CLI args > env > YAML > defaults."""
    config_path = getattr(args, "config", None)
    if config_path is not None:
        from pathlib import Path
        yaml_path = Path(config_path)
    else:
        yaml_path = default_config_path()

    yaml_section = load_yaml_section(yaml_path, "aura-msg")
    return resolve_connection(
        cli_args={
            "namespace": getattr(args, "namespace", None),
            "task_queue": getattr(args, "task_queue", None),
            "server_address": getattr(args, "server_address", None),
        },
        yaml_section=yaml_section,
    )


async def _cmd_query_state(args: argparse.Namespace) -> None:
    """aura-msg query state — query epoch state from EpochWorkflow."""
    from temporalio.client import Client
    from temporalio.service import RPCError, RPCStatusCode
    from aura_protocol.workflow import EpochWorkflow

    conn = _resolve_conn(args)
    fmt = getattr(args, "format", "json")

    try:
        client = await Client.connect(
            conn.server_address,
            namespace=conn.namespace,
        )
    except Exception as exc:
        print(
            f"aura-msg: connection error — {exc}\n"
            f"  Where:  {conn.server_address} (namespace={conn.namespace})\n"
            f"  Why:    Could not connect to Temporal server\n"
            f"  Fix:    Verify aurad is running and server-address is correct",
            file=sys.stderr,
        )
        sys.exit(2)

    try:
        handle = client.get_workflow_handle(args.epoch_id)
        result = await handle.query(EpochWorkflow.full_state)
    except RPCError as exc:
        if exc.status == RPCStatusCode.NOT_FOUND:
            print(
                f"aura-msg: workflow error — workflow '{args.epoch_id}' not found\n"
                f"  Where:  {conn.server_address} (namespace={conn.namespace})\n"
                f"  Why:    No running workflow with ID '{args.epoch_id}'\n"
                f"  Fix:    Check epoch-id or start the epoch with 'aura-msg epoch start'",
                file=sys.stderr,
            )
            sys.exit(3)
        print(
            f"aura-msg: workflow error — {exc}\n"
            f"  Where:  epoch-id={args.epoch_id}\n"
            f"  Fix:    Check workflow status in Temporal UI",
            file=sys.stderr,
        )
        sys.exit(3)
    except Exception as exc:
        exc_str = str(exc)
        if "not found" in exc_str.lower() or "does not exist" in exc_str.lower():
            print(
                f"aura-msg: workflow error — workflow '{args.epoch_id}' not found\n"
                f"  Where:  {conn.server_address} (namespace={conn.namespace})\n"
                f"  Why:    No running workflow with ID '{args.epoch_id}'\n"
                f"  Fix:    Check epoch-id or start the epoch with 'aura-msg epoch start'",
                file=sys.stderr,
            )
            sys.exit(3)
        print(
            f"aura-msg: workflow error — {exc}\n"
            f"  Where:  epoch-id={args.epoch_id}\n"
            f"  Fix:    Check workflow status in Temporal UI",
            file=sys.stderr,
        )
        sys.exit(3)

    print(format_epoch_state(result, fmt=fmt))


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    """Parse CLI arguments.

    Args:
        argv: Argument list to parse. Defaults to sys.argv[1:] when None.

    Returns:
        Parsed namespace with .group and .subcommand attributes.
    """
    return build_parser().parse_args(argv)


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if args.group is None:
        parser.print_help()
        sys.exit(0)

    group = args.group
    subcommand = getattr(args, "subcommand", None)
    if subcommand is None:
        parser.parse_args([group, "--help"])
        sys.exit(0)

    # Dispatch implemented subcommands
    if group == "query" and subcommand == "state":
        asyncio.run(_cmd_query_state(args))
        return

    # Not yet implemented
    print(
        f"aura-msg: '{group} {subcommand}' is not yet implemented",
        file=sys.stderr,
    )
    sys.exit(1)


if __name__ == "__main__":
    main()
